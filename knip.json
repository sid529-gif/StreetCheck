{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "exclude": ["exports", "types", "duplicates"],
  "workspaces": {
    ".": {
      "entry": ["eslint.config.js"],
      "ignoreDependencies": [
        "concurrently",
        "husky",
        "lint-staged",
        "git-cliff",
        "gitleaks",
        "prisma",
        "oxlint"
      ]
    },
    "client": {
      "entry": ["src/main.tsx"],
      "ignoreDependencies": [
        "@types/react",
        "@types/react-dom",
        "zod",
        "eslint-plugin-react",
        "eslint-plugin-react-hooks",
        "axios",
        "geojson"
      ]
    },
    "server": {
      "entry": ["src/index.ts"],
      "ignoreDependencies": [
        "@types/express",
        "@types/cors",
        "@types/multer",
        "@types/node-cron",
        "@types/jsonwebtoken",
        "cloudinary",
        "jsonwebtoken",
        "multer",
        "node-fetch"
      ]
    },
    "shared": {
      "entry": ["src/index.ts"],
      "ignoreDependencies": ["@vitest/coverage-v8"]
    }
  },
  "ignore": [
    "**/.specify/**",
    "**/.speckit/**",
    "**/dist/**",
    "**/coverage/**",
    "ai-service/**"
  ]
}
