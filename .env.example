# StreetCheck — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://streetcheck:streetcheck_dev@localhost:5432/streetcheck"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ── AI Services ───────────────────────────────────────────────────────────────
# Claude API — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Internal secret shared between Express and the Python AI micro-service
AI_SERVICE_SECRET=change-me-in-production

# URL of the Python FastAPI AI micro-service
AI_SERVICE_URL=http://localhost:8001

# ── Media Uploads ─────────────────────────────────────────────────────────────
# Cloudinary — get from https://cloudinary.com/console
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://...

# ── Data Ingestion ────────────────────────────────────────────────────────────
# Set to 'true' to poll the full Hyderabad bounding box (17.2–17.6°N, 78.3–78.6°E)
# Set to 'false' (default) to use the tighter hackathon demo bbox (Kondapur–Gachibowli area)
OVERPASS_FULL_CITY=false

# Optional: Override the Overpass API endpoint
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# ── Auth (future) ─────────────────────────────────────────────────────────────
# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# (Not used in Phase 0; citizen reporting is anonymous via device token)
# JWT_SECRET=
# JWT_REFRESH_SECRET=
