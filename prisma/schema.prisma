generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Road Segments ─────────────────────────────────────────────────────────────
// geometry is stored as a GeoJSON LineString object (Json column).
// For spatial bbox queries use $queryRaw with PostGIS — see server/src/db/geoQueries.ts
model RoadSegment {
  id               String   @id @default(cuid())
  osmWayId         BigInt   @unique @map("osm_way_id")
  name             String?
  geometry         Json     // GeoJSON LineString { type, coordinates }
  bbox             Json     // { minLng, minLat, maxLng, maxLat }

  // Score dimensions — all normalised to [0.0, 1.0]
  lightingScore    Float    @default(0.5)   @map("lighting_score")
  accidentRate     Float    @default(0.1)   @map("accident_rate")
  floodRisk        Float    @default(0.1)   @map("flood_risk")
  surfaceQuality   Float    @default(0.7)   @map("surface_quality")
  walkabilityScore Float    @default(0.5)   @map("walkability_score")

  // Computed — updated by scoringEngine after each refresh or report
  safetyScore      Float    @default(0.0)   @map("safety_score")
  safetyBand       String   @default("amber") @map("safety_band") // green | amber | red
  scoringVersion   Int      @default(1)     @map("scoring_version")

  // OSM tag cache
  osmLit           String?  @map("osm_lit")       // yes | no | 24/7 | null
  osmSurface       String?  @map("osm_surface")   // asphalt | unpaved | etc
  osmHighway       String?  @map("osm_highway")   // primary | residential | etc
  osmFootway       String?  @map("osm_footway")   // yes | no | null
  osmSidewalk      String?  @map("osm_sidewalk")  // yes | both | left | right | no | null

  activeReports    Int      @default(0) @map("active_reports")
  reports          HazardReport[]

  lastOsmSync      DateTime @default(now()) @map("last_osm_sync")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt      @map("updated_at")

  @@index([safetyScore], name: "road_segments_safety_score_idx")
  @@index([safetyBand],  name: "road_segments_safety_band_idx")
  @@map("road_segments")
}

// ── Hazard Reports ────────────────────────────────────────────────────────────
model HazardReport {
  id             String   @id @default(cuid())
  anonymousToken String   @map("anonymous_token") // client-generated UUID — no PII
  segmentId      String   @map("segment_id")
  segment        RoadSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  hazardType     String   @map("hazard_type")    // HazardType enum value
  severityWeight Float    @default(0.5) @map("severity_weight") // 0.0–1.0

  description    String?
  photoUrl       String?  @map("photo_url")       // Cloudinary HTTPS URL

  // AI pipeline outputs
  cvHazardType   String?  @map("cv_hazard_type")
  cvConfidence   Float?   @map("cv_confidence")
  nlpHazardType  String?  @map("nlp_hazard_type")
  nlpConfidence  Float?   @map("nlp_confidence")

  lat            Float
  lng            Float

  expiresAt      DateTime @map("expires_at")      // default: createdAt + 72h
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([segmentId],      name: "hazard_reports_segment_idx")
  @@index([anonymousToken], name: "hazard_reports_token_idx")
  @@index([expiresAt],      name: "hazard_reports_expires_idx")
  @@map("hazard_reports")
}

// ── Data Refresh Log ──────────────────────────────────────────────────────────
model DataRefreshLog {
  id         String   @id @default(cuid())
  source     String   // osm_overpass | telangana_open | hydraa | morth
  status     String   // success | failure | partial
  recordsIn  Int      @default(0) @map("records_in")
  recordsOut Int      @default(0) @map("records_out")
  durationMs Int      @default(0) @map("duration_ms")
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([source, createdAt], name: "data_refresh_log_source_idx")
  @@map("data_refresh_log")
}

// ── Citizen Reviews ───────────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int      @default(5)
  comment   String
  email     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}
