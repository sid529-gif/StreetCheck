{
  "name": "@streetcheck/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Zod schemas and TypeScript types for StreetCheck",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./scoring": "./src/scoring/weights.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "eslint": "^9.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
